{
  "name": "schrune-vscode-extension",
  "displayName": "Schrune",
  "description": "Syntax highlighting, autocomplete, and CLI shortcuts for Schrune",
  "version": "1.0.0",
  "publisher": "irampton",
  "repository": {
    "type": "git",
    "url": "https://github.com/irampton/Schrune_VSCode_Extension.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:schrune",
    "onCommand:schrune.buildProject",
    "onCommand:schrune.buildCurrentFile",
    "onCommand:schrune.buildFile",
    "onCommand:schrune.addPart",
    "onCommand:schrune.openProject",
    "onCommand:schrune.installParts",
    "onCommand:schrune.createProject",
    "onView:schruneCliView"
  ],
  "main": "./extension.js",
  "files": [
    "extension.js",
    "language-configuration.json",
    "media/**",
    "snippets/**",
    "syntaxes/**",
    "README.md",
    "LICENSE"
  ],
  "contributes": {
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": [
              "keyword.declaration.schrune",
              "storage.type.javascript.schrune"
            ],
            "settings": { "foreground": "#E57373" }
          },
          {
            "scope": [
              "keyword.control.schrune",
              "punctuation.section.parentheses.schrune",
              "punctuation.section.parentheses.begin.schrune",
              "punctuation.section.parentheses.end.schrune",
              "punctuation.section.brackets.schrune",
              "punctuation.section.brackets.begin.schrune",
              "punctuation.section.brackets.end.schrune",
              "punctuation.section.braces.schrune",
              "punctuation.definition.type.schrune",
              "punctuation.definition.type.begin.schrune",
              "punctuation.definition.type.end.schrune",
              "variable.parameter.named.schrune",
              "keyword.operator.named-argument.schrune"
            ],
            "settings": { "foreground": "#C586C0" }
          },
          {
            "scope": [
              "punctuation.section.module.begin.schrune",
              "punctuation.section.module.end.schrune",
              "variable.other.readwrite.javascript.schrune"
            ],
            "settings": { "foreground": "#FFD707" }
          },
          {
            "scope": [
              "entity.name.type.module.schrune",
              "entity.name.variable.module.schrune",
              "entity.name.type.part.schrune",
              "entity.name.variable.part.schrune",
              "entity.name.namespace.require.schrune"
            ],
            "settings": { "foreground": "#4DC7AE" }
          },
          {
            "scope": [
              "constant.numeric.schrune",
              "constant.language.boolean.schrune",
              "string.quoted.double.schrune",
              "string.quoted.single.schrune",
              "constant.character.escape.schrune"
            ],
            "settings": { "foreground": "#9CDCFE" }
          },
          {
            "scope": "entity.name.variable.net.schrune",
            "settings": { "foreground": "#79C0FF" }
          },
          {
            "scope": "variable.other.property.rail-side.schrune",
            "settings": { "foreground": "#4FC3F7" }
          },
          {
            "scope": "variable.other.property.declaration.schrune",
            "settings": { "foreground": "#FF946C" }
          },
          {
            "scope": "keyword.import.from.schrune",
            "settings": { "foreground": "#FF946C" }
          },
          {
            "scope": "punctuation.separator.module-parameter.schrune",
            "settings": { "foreground": "#FFFFFF" }
          }
        ]
      },
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "schruneNet:schrune": "#79C0FF",
          "schruneComponent:schrune": "#4DC7AE",
          "schruneLocal:schrune": "#FFD707"
        }
      }
    },
    "semanticTokenTypes": [
      {
        "id": "schruneNet",
        "superType": "variable",
        "description": "A Schrune net or rail"
      },
      {
        "id": "schruneComponent",
        "superType": "class",
        "description": "A Schrune part or module"
      },
      {
        "id": "schruneLocal",
        "superType": "variable",
        "description": "A Schrune let or const variable"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "schrune",
        "scopes": {
          "schruneNet": ["entity.name.variable.net.schrune"],
          "schruneComponent": ["entity.name.variable.part.schrune"],
          "schruneLocal": ["variable.other.readwrite.javascript.schrune"]
        }
      }
    ],
    "languages": [
      {
        "id": "schrune",
        "aliases": [
          "Schrune"
        ],
        "extensions": [
          ".schrune"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "schrune",
        "scopeName": "source.schrune",
        "path": "./syntaxes/schrune.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "schrune",
        "path": "./snippets/schrune.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "schrune.buildProject",
        "title": "Schrune: Build Selected Project"
      },
      {
        "command": "schrune.addPart",
        "title": "Schrune: Add LCSC Part..."
      },
      {
        "command": "schrune.openProject",
        "title": "Schrune: Open Project in KiCad"
      },
      {
        "command": "schrune.installParts",
        "title": "Schrune: Install Project Parts"
      },
      {
        "command": "schrune.createProject",
        "title": "Schrune: Create Project..."
      },
      {
        "command": "schrune.refreshCliView",
        "title": "Schrune: Refresh CLI Panel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "schruneTools",
          "title": "Schrune",
          "icon": "media/schrune.svg"
        }
      ]
    },
    "views": {
      "schruneTools": [
        {
          "id": "schruneCliView",
          "name": "CLI",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Schrune",
      "properties": {
        "schrune.cli.executable": {
          "type": "string",
          "default": "",
          "description": "CLI executable to run for Schrune commands. Leave empty to auto-detect a local Schrune checkout or fall back to schrune on PATH."
        },
        "schrune.cli.scriptPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to the Schrune Node entrypoint. Set this when schrune.cli.executable should be node."
        }
      }
    }
  },
  "scripts": {
    "test": "node --check extension.js"
  },
  "devDependencies": {},
  "dependencies": {}
}
