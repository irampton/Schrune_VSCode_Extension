{
  "name": "schrune-vscode-extension",
  "displayName": "Schrune",
  "description": "Syntax highlighting, autocomplete, and CLI shortcuts for Schrune",
  "version": "1.0.0",
  "publisher": "irampton",
  "repository": {
    "type": "git",
    "url": "https://github.com/irampton/Schrune_VSCode_Extension.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:schrune",
    "onCommand:schrune.buildProject",
    "onCommand:schrune.buildCurrentFile",
    "onCommand:schrune.buildFile",
    "onCommand:schrune.addPart",
    "onCommand:schrune.openProject",
    "onCommand:schrune.installParts",
    "onCommand:schrune.createProject",
    "onView:schruneCliView"
  ],
  "main": "./extension.js",
  "files": [
    "extension.js",
    "language-configuration.json",
    "media/**",
    "snippets/**",
    "syntaxes/**",
    "README.md",
    "LICENSE"
  ],
  "contributes": {
    "languages": [
      {
        "id": "schrune",
        "aliases": [
          "Schrune"
        ],
        "extensions": [
          ".schrune"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "schrune",
        "scopeName": "source.schrune",
        "path": "./syntaxes/schrune.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "schrune",
        "path": "./snippets/schrune.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "schrune.buildProject",
        "title": "Schrune: Build Selected Project"
      },
      {
        "command": "schrune.addPart",
        "title": "Schrune: Add LCSC Part..."
      },
      {
        "command": "schrune.openProject",
        "title": "Schrune: Open Project in KiCad"
      },
      {
        "command": "schrune.installParts",
        "title": "Schrune: Install Project Parts"
      },
      {
        "command": "schrune.createProject",
        "title": "Schrune: Create Project..."
      },
      {
        "command": "schrune.refreshCliView",
        "title": "Schrune: Refresh CLI Panel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "schruneTools",
          "title": "Schrune",
          "icon": "media/schrune.svg"
        }
      ]
    },
    "views": {
      "schruneTools": [
        {
          "id": "schruneCliView",
          "name": "CLI",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Schrune",
      "properties": {
        "schrune.cli.executable": {
          "type": "string",
          "default": "",
          "description": "CLI executable to run for Schrune commands. Leave empty to auto-detect a local Schrune checkout or fall back to schrune on PATH."
        },
        "schrune.cli.scriptPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to the Schrune Node entrypoint. Set this when schrune.cli.executable should be node."
        }
      }
    }
  },
  "scripts": {
    "test": "node --check extension.js"
  },
  "devDependencies": {},
  "dependencies": {}
}
